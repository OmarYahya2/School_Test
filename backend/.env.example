PORT=3001
DATABASE_URL="postgresql://username:password@hostname:port/database?sslmode=require"
JWT_SECRET="super-secret-key-change-me-in-production-1234567890"
JWT_EXPIRES_IN="15m"

# Authentication Security (Refresh Tokens)
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me-in-production-0987654321"
JWT_REFRESH_EXPIRES_IN="7d"

# Scalability & Caching
# REDIS_URL="redis://localhost:6379"

# Observability
LOG_FORMAT="color" # Options: color, json

# Cloud Storage (Optional)
STORAGE_PROVIDER="local" # Options: local, s3
# AWS_ACCESS_KEY_ID="your-aws-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="your-s3-bucket-name"
